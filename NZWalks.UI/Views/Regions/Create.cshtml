
@model NZWalks.UI.Models.CreateRegionViewModel;
@{
    ViewData["Title"] = "Create Region";
}

<h1 class="mt-3">Create Region</h1>
<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label for="name" class="form-label">Name</label>
        <input type="text" class="form-control" id="name" name="name" asp-for="Name" required>
    </div>
    <div class="mb-3">
        <label for="code" class="form-label">Code</label>
        <input type="text" class="form-control" id="code" name="code" asp-for="Code" required>
    </div>
    
    <div class="mb-3">
        <label for="regionImage" class="form-label">Region Image</label>
        <input type="file" class="form-control" id="regionImage" name="regionImage" asp-for="RegionImageUrl">
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
