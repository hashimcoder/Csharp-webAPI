@model IEnumerable<NZWalks.UI.Models.DTO.RegionDto>

    @{

    }

    <h1 class="mt-3">Regions</h1>

    <table class="table table-bordered">
        <thead>
            <tr>Id</tr>
            <tr>Name</tr>
            <tr>Code</tr>
        </thead> 
        <tbody>
            @foreach (var region in Model)
            {
                <tr>
                    <td>@region.Id</td>
                    <td>@region.Name</td>
                    <td>@region.Code</td>
                </tr>
            }
        </tbody>
    </table>